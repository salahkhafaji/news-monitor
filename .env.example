# ============================================
# NEWS MONITOR - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual API keys
# Never commit .env to version control!

# --------------------------------------------
# BLOCK 1: NewsAPI (https://newsapi.org/)
# --------------------------------------------
# Get your free API key from: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# --------------------------------------------
# BLOCK 2: Supabase (https://supabase.com/)
# --------------------------------------------
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# --------------------------------------------
# BLOCK 4: Google Gemini AI (https://makersuite.google.com/app/apikey)
# --------------------------------------------
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------
# BLOCK 5: Telegram Bot (https://t.me/BotFather)
# --------------------------------------------
# Create a bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal chat ID (get it by sending a message to your bot)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --------------------------------------------
# OPTIONAL: Default keywords (comma-separated)
# --------------------------------------------
# Uncomment and modify if you want to use multiple keywords
# DEFAULT_KEYWORDS=technology,Tesla,Bitcoin,AI

# ============================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and fill in your actual API keys
# 3. Never share your .env file or commit it to git!
# ============================================
